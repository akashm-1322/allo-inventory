# Postgres connection string from Supabase, Neon, or Railway
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Redis URL from Upstash (or any Redis provider)
# Format: redis://:password@host:port or rediss://:password@host:port (TLS)
REDIS_URL="redis://:password@host:6379"

# Secret for protecting the cron endpoint (generate with: openssl rand -hex 32)
CRON_SECRET="your-cron-secret-here"
